# SSH credentials for Server Manager (do not commit)
SSH_HOST=46.224.210.19
SSH_PORT=22
SSH_USER=root
# Path to PEM private key (Docker default mounts workspace key here)
SSH_PRIVATE_KEY_PATH=/run/secrets/azaf-codes.pem
# Only if the key is encrypted:
# SSH_PRIVATE_KEY_PASSPHRASE=
# On VPS deploy, scripts set SSH_HOST=host.docker.internal

# —— Watchdog ——
# Comma-separated public HTTPS URLs to probe every interval
WATCHDOG_URLS=https://coolify.azafcodes.co.uk/,https://azafcodes.co.uk/,https://kinventory.azafcodes.co.uk/,https://who-owes-who.azafcodes.co.uk/
WATCHDOG_INTERVAL_MS=60000
DISK_ALERT_PCT=90
MEM_ALERT_PCT=90

# Telegram alerts (optional but recommended)
# Create a bot via @BotFather, then message it and get chat id via getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# —— Backups ——
# Format: engine:container:dbname[:user] (comma-separated)
# Postgres uses container $POSTGRES_USER if user omitted; MySQL uses root + $MYSQL_ROOT_PASSWORD
BACKUP_TARGETS=postgres:coolify-db:coolify,mysql:fustqja2jtg6lwbiil1hm6ho:kinventory,mysql:fustqja2jtg6lwbiil1hm6ho:rent_tracker,mysql:fustqja2jtg6lwbiil1hm6ho:who_owes_who
BACKUP_REMOTE_DIR=/root/server-manager-backups
# Keep low to stay inside Cloudflare R2 free tier (10 GB). Do not raise casually.
BACKUP_KEEP_DAYS=7

# Cloudflare R2 — bucket already provisioned (see INVENTORY.md).
# Needs `aws` CLI on the SSH host (deploy-vps.sh installs if missing).
# Keys: copy from real .env or recreate via R2 → Manage API Tokens (Object Read & Write).
BACKUP_S3_ENDPOINT=https://b18eee30d3f2e5e888b4aa0869d831ad.r2.cloudflarestorage.com
BACKUP_S3_BUCKET=server-manager-backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_REGION=auto

# —— Laravel queues (generic monitoring) ——
# Format: id:labelKey=labelValue:Display Name (comma-separated)
# Coolify apps resolve by coolify.projectName (stable across redeploys; coolify.name is random)
QUEUE_APPS=kinventory:coolify.projectName=kinventory:KInventory,rent-tracker:coolify.projectName=rent-tracker:Rent Tracker,who-owes-who:coolify.projectName=who-owes-who:Who Owes Who
# Telegram when worker is down or failed_jobs > 0 (1=on, 0=off)
QUEUE_FAILED_ALERT=1

# —— Production UI auth (used by scripts/gen-htpasswd.sh) ——
# AUTH_USER=admin
